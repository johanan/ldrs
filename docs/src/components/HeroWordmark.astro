---
import Wordmark from "./Wordmark.astro";

// Starlight's anchor target for skip-to-content links.
const PAGE_TITLE_ID = "_top";

const { tagline } =
  Astro.locals.starlightRoute.entry.data.hero || {};
---

<div class="hero">
  <h1 id={PAGE_TITLE_ID} data-page-title class="wordmark-h1">
    <Wordmark font="dos-rebel" as="svg" />
  </h1>
  {tagline && <p class="tagline" set:html={tagline} />}
</div>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5rem;
  }
  .wordmark-h1 {
    margin: 0;
    color: var(--sl-color-accent);
    width: min(100%, 28rem);
  }
  .wordmark-h1 :global(svg) {
    width: 100%;
    height: auto;
    display: block;
  }
  .tagline {
    font-size: clamp(
      var(--sl-text-base),
      calc(0.0625rem + 1.5vw),
      var(--sl-text-xl)
    );
    color: var(--sl-color-gray-2);
    max-width: 50ch;
    margin: 0;
    align-self: flex-start;
    text-align: start;
  }
</style>
